GEMINI_API_KEY=

# Service Account (recommended) — download from Google Cloud Console
GOOGLE_SERVICE_ACCOUNT_PATH=service-account.json

# Your Google Calendar ID (usually your email address)
# Use "primary" if using OAuth, or your email if using service account
GOOGLE_CALENDAR_ID=

# Timezone for calendar events
CALENDAR_TIMEZONE=UTC

# Gmail SMTP for sending calendar invite emails to attendees
# Create App Password: https://myaccount.google.com/apppasswords
SMTP_EMAIL=your-email@gmail.com
SMTP_APP_PASSWORD=your_16_char_app_password

# Legacy OAuth (fallback if service account not found)
# GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
