GEMINI_API_KEY=

# Local: path to downloaded key (see service-account.json.example)
GOOGLE_SERVICE_ACCOUNT_PATH=service-account.json

# Deploy (Docker / DigitalOcean / Render): paste entire JSON as ONE line, OR use base64:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SERVICE_ACCOUNT_JSON_B64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii....
# Generate base64:  python3 -c "import base64; print(base64.b64encode(open('service-account.json','rb').read()).decode())"

# Your Google Calendar ID (usually your email — calendar must be shared with the service account)
GOOGLE_CALENDAR_ID=

CALENDAR_TIMEZONE=UTC

SMTP_EMAIL=your-email@gmail.com
SMTP_APP_PASSWORD=your_16_char_app_password

# GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json
